  "html": "<style>\n    /* Import official-looking Arabic font */\n    @import url(\"https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap\");\n\n    .custom-report-container { \n        direction: rtl; \n        font-family: \"Cairo\", \"Segoe UI\", sans-serif; \n        padding: 30px; \n        background-color: #ffffff;\n        color: #1e293b;\n    }\n    \n    /* Elegant Header with UOT Colors (Navy Blue & Gold) */\n    .report-header-wrapper {\n        text-align: center;\n        border-bottom: 3px solid #f59e0b; /* UOT Gold accent */\n        padding-bottom: 15px;\n        margin-bottom: 30px;\n    }\n    .report-header-wrapper h1 {\n        color: #1e3a8a; /* Deep Navy Blue */\n        font-size: 26px;\n        font-weight: 700;\n        margin: 0 0 5px 0;\n    }\n    .report-header-wrapper h2 { \n        color: #475569; \n        font-size: 18px; \n        font-weight: 600;\n        margin: 0; \n    }\n\n    /* Styled Filters Section */\n    .filters-summary { \n        margin-bottom: 25px; \n        font-size: 14px; \n        background-color: #f8fafc; \n        padding: 15px; \n        border-right: 4px solid #1e3a8a; /* Blue side-border */\n        border-radius: 4px;\n    }\n    .filters-summary strong { color: #1e3a8a; }\n\n    /* Premium Table Styling */\n    .custom-report-table { \n        width: 100%; \n        border-collapse: collapse; \n        font-size: 14px; \n        margin-bottom: 40px;\n    }\n    .custom-report-table th, .custom-report-table td { \n        border: 1px solid #cbd5e1; \n        padding: 12px 15px; \n        text-align: right; \n    }\n    .custom-report-table th { \n        background-color: #1e3a8a; /* Navy Blue Headers */\n        color: #ffffff; \n        font-weight: 600; \n    }\n    .custom-report-table tbody tr:nth-child(even) {\n        background-color: #f1f5f9; /* Subtle Zebra Striping */\n    }\n\n    /* Official Signatures Section for Printing */\n    .official-footer {\n        display: flex;\n        justify-content: space-around;\n        margin-top: 50px;\n        text-align: center;\n        page-break-inside: avoid;\n    }\n    .signature-box {\n        width: 200px;\n    }\n    .signature-line {\n        border-top: 1px solid #1e293b;\n        margin-bottom: 10px;\n    }\n    .signature-title {\n        font-weight: 700;\n        color: #1e3a8a;\n        font-size: 16px;\n    }\n    \n    /* Ensure colors print correctly */\n    @media print {\n        .custom-report-table th {\n            background-color: #1e3a8a !important;\n            color: #ffffff !important;\n            -webkit-print-color-adjust: exact;\n        }\n        .report-header-wrapper {\n            border-bottom: 3px solid #f59e0b !important;\n        }\n        .filters-summary {\n            border-right: 4px solid #1e3a8a !important;\n            background-color: #f8fafc !important;\n            -webkit-print-color-adjust: exact;\n        }\n    }\n</style>\n\n<div class=\"custom-report-container\">\n    \n    {% \n        var report_title = \"تقرير الاجازات لكلية الهندسة الميكانيكية\";\n        if (typeof filters !== \"undefined\" && filters && filters.from_day) {\n            var date_parts = filters.from_day.split(\"-\");\n            if (date_parts.length === 3) {\n                var year_num = date_parts[0];\n                var month_num = parseInt(date_parts[1], 10); \n                report_title = \"تقرير الاجازات عن شهر \" + month_num + \" لسنة \" + year_num;\n            }\n        }\n    %}\n\n    <div class=\"report-header-wrapper\">\n        <h1>الجامعة التكنولوجية - كلية الهندسة الميكانيكية</h1>\n        <h2>{%= report_title %}</h2>\n    </div>\n\n    {% if (typeof filters !== \"undefined\" && filters && Object.keys(filters).length > 0) { %}\n    <div class=\"filters-summary\">\n        <strong>الفلاتر المطبقة:</strong>\n        {% if (filters.from_day) { %} | من تاريخ: <b>{%= filters.from_day %}</b> {% } %}\n        {% if (filters.to_day) { %} | إلى تاريخ: <b>{%= filters.to_day %}</b> {% } %}\n        {% if (filters.leave_type) { %} | نوع الإجازة: <b>{%= __(filters.leave_type) %}</b> {% } %}\n        {% if (filters.workflow_state) { %} | حالة الطلب: <b>{%= __(filters.workflow_state) %}</b> {% } %}\n    </div>\n    {% } %}\n\n    <table class=\"custom-report-table\">\n        <thead>\n            <tr>\n                <th>الاسم الكامل</th>\n                <th>عدد أيام الإجازة</th>\n                <th>من تاريخ</th>\n                <th>إلى تاريخ</th>\n                <th>نوع الإجازة</th>\n                <th>حالة الطلب</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% if (typeof data !== \"undefined\" && data && data.length > 0) { %}\n                {% for (var i = 0; i < data.length; i++) { %}\n                    <tr>\n                        <td>{% if(data[i].data_lprk) { %} {%= data[i].data_lprk %} {% } else { %} - {% } %}</td>\n                        <td>{% if(data[i].days_count_of_leave) { %} {%= data[i].days_count_of_leave %} {% } else { %} 0 {% } %}</td>\n                        <td>{% if(data[i].from_day) { %} {%= data[i].from_day %} {% } else { %} - {% } %}</td>\n                        <td>{% if(data[i].to_day) { %} {%= data[i].to_day %} {% } else { %} - {% } %}</td>\n                        \n                        <td>{% if(data[i].leave_type) { %} {%= __(data[i].leave_type) %} {% } else { %} - {% } %}</td>\n                        <td>{% if(data[i].workflow_state) { %} {%= __(data[i].workflow_state) %} {% } else { %} - {% } %}</td>\n                    </tr>\n                {% } %}\n            {% } else { %}\n                <tr>\n                    <td colspan=\"6\" style=\"text-align: center; padding: 40px; font-weight: 600; color: #64748b;\">\n                        لا توجد بيانات مطابقة لهذه الفلاتر\n                    </td>\n                </tr>\n            {% } %}\n        </tbody>\n    </table>\n\n    <div class=\"official-footer\">\n        <div class=\"signature-box\">\n            <div class=\"signature-line\"></div>\n            <div class=\"signature-title\">مـعـاون الـعـمـيـد للشؤون الادارية</div>\n        </div>\n        <div class=\"signature-box\">\n            <div class=\"signature-line\"></div>\n            <div class=\"signature-title\">عـمـيـد الـكـلـيـة</div>\n        </div>\n    </div>\n\n</div>",
