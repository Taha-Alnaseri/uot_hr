-weight: bold;\n        }\n        .badge2 {\n            display: inline-block;\n            background-color: #aef6b5;\n            color: #386934;\n            padding: 4px 12px;\n            border-radius: 20px;\n            font-size: 13px;\n            font-weight: bold;\n        }\n        .badge3 {\n            display: inline-block;\n            background-color: #f6aeae;\n            color: #8b3d3d;\n            padding: 4px 12px;\n            border-radius: 20px;\n            font-size: 13px;\n            font-weight: bold;\n        }\n        .badge4 {\n            display: inline-block;\n            background-color: #aecdf6;\n            color: #383469;\n            padding: 4px 12px;\n            border-radius: 20px;\n            font-size: 13px;\n            font-weight: bold;\n        } \n        .badge5 {\n            display: inline-block;\n            background-color: #fff3cd;\n            color: #856404;\n            padding: 4px 12px;\n            border-radius: 20px;\n            font-size: 13px;\n            font-weight: bold;\n        }         \n        .notice {\n            background-color: #e8f4fd;\n            border-right: 4px solid #1a73e8;\n            padding: 15px;\n            border-radius: 5px;\n            font-size: 14px;\n            color: #555;\n            margin: 20px 0;\n        }\n        .footer {\n            background-color: #f8f8f8;\n            padding: 20px 30px;\n            text-align: center;\n            font-size: 12px;\n            color: #999;\n            border-top: 1px solid #eee;\n        }\n    </style>\n</head>\n<body>\n\n    {% set status_map2 = {\n    'Pending': 'badge1',\n    'Approved': 'badge2',\n    'Rejected': 'badge3',\n    'approved by the line manager': 'badge4',\n    'Approved by the Administrative Associate': 'badge4'\n    } %}\n\n    {% set status_map = {\n    'Pending': 'قيد الانتظار',\n    'Approved': 'تم الموافق عليه',\n    'Rejected': 'مرفوض',\n    'approved by the line manager': 'تمت موافقة المدير المباشر',\n    'Approved by the Administrative Associate': 'تمت موافقة المعاون الإداري'\n    } %}\n\n    <div class=\"container\">\n\n        <!-- Header -->\n        <div class=\"header\">\n            <h1>الجامعة التكنولوجية - كلية الهندسة الميكانيكية</h1>\n            <p>طلب أجازة</p>\n        </div>\n\n        <!-- Body -->\n        <div class=\"body\">\n\n            <p class=\"greeting\">\n                السلام عليكم ورحمة الله وبركاته،<br>\n                عزيزي <strong>{{ doc.data_lprk }}</strong>،\n            </p>\n\n            <p style=\"color: #555; font-size: 15px;\">\n                نود اعلامكم انه تم تحديث حالة طلب الاجازة المقدم من قبلكم و كما مبين ادناه.\n            </p>\n\n            <!-- Details Table -->\n            <table class=\"info-table\">\n                <tr>\n                    <td>رقم الطلب</td>\n                    <td><strong>{{ doc.name }}</strong></td>\n                </tr>\n                <tr>\n                    <td>الرقم الوظيفي</td>\n                    <td>{{ doc.employee }}</td>\n                </tr>\n                <tr>\n                    <td>الاسم الكامل</td>\n                    <td>{{ doc.data_lprk }}</td>\n                </tr>\n                <tr>\n                    <td>نوع الإجازة</td>\n                    {% set leave_type_name = frappe.db.get_value(\"UOT Leave Type\", doc.leave_type, \"leave_type\") %}\n                    <td>{{ leave_type_name }}</td>\n                </tr>\n                <tr>\n                    <td>تاريخ تأريخ بدأ الاجازة</td>\n                    <td>{{ doc.from_day }}</td>\n                </tr>\n                <tr>\n                    <td>تاريخ تأريخ انتهاء الاجازة</td>\n                    <td>{{ doc.to_day }}</td>\n                </tr>\n                <tr>\n                    <td>عدد الأيام</td>\n                    <td>{{ doc.days_count_of_leave }} يوم</td>\n                </tr>\n                {% set leave_type_name2 = frappe.db.get_value('UOT Leave Type', doc.leave_type, 'leave_type') %}\n                {% if doc.leave_type == 'Leave Type- 003' %}\n                <tr>\n                    <td>سبب الإجازة</td>\n                    <td>{{ leave_type_name2 }}</td>\n                </tr>\n                {% else %}\n                <tr>\n                    <td>سبب الإجازة</td>\n                    <td>{{ doc.reason_for_leave }}</td>\n                </tr>\n                {% endif %}\n                <tr>\n                    <td>حالة الطلب</td>\n                    <td>\n                        <span class=\" {{ status_map2.get(doc.workflow_state, badge1) }} \">{{ status_map.get(doc.workflow_state, doc.workflow_state) }}</span>\n                    </td>\n                </tr>\n            </table>\n\n            <!-- Notice -->\n            <div class=\"notice\">\n                 في حال وجود أي استفسار يرجى التواصل مع شعبة الموارد البشرية.\n            </div>\n\n        </div>\n\n        <!-- Footer -->\n        <div class=\"footer\">\n            <p>هذه رسالة آلية من نظام إدارة الموارد البشرية - الجامعة التكنولوجية - كلية الهندسة الميكانيكية</p>\n            <p>يرجى عدم الرد على هذا البريد الإلكتروني</p>\n        </div>\n\n    </div>\n</body>\n</html>\n",
